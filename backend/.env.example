# ---------------------------------------------------------------------------
# SignOff — Backend environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Google Cloud Platform / Vertex AI ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
# Path to a service-account JSON key (omit on Cloud Run, which uses ADC).
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_MODEL=gemini-2.5-flash

# --- Firestore (State & Audit Trail) ---
# Firestore uses GCP_PROJECT_ID. Optional named database (defaults to "(default)").
FIRESTORE_DATABASE=(default)
FIRESTORE_AUDIT_COLLECTION=mesh_audit_trail

# --- Neo4j (Precedents / Citations Graph) ---
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# --- Perplexity AI (Live Legal Research) ---
# Use a current Sonar model. `sonar-pro` is a good default; `sonar` and
# `sonar-reasoning-pro` also work. (The older `sonar-reasoning` is deprecated.)
PERPLEXITY_API_KEY=your-perplexity-api-key
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_BASE_URL=https://api.perplexity.ai

# --- NVIDIA NIM / Nemotron High-Security Risk Agent ---
# Default is NVIDIA's hosted, OpenAI-compatible API. Set NVIDIA_API_KEY (nvapi-...)
# to go live. For true on-prem processing, point NIM_BASE_URL at a self-hosted
# NIM container instead. Set NIM_MOCK=true to force the offline heuristic.
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=your-nvidia-api-key
NIM_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
NIM_MOCK=false

# --- CORS (Lovable React frontend) ---
# Comma-separated list of allowed origins. Lovable's dev server runs on :8080,
# Vite's default is :5173. The *.lovable.app/.dev origins are allowed via regex.
CORS_ALLOW_ORIGINS=http://localhost:8080,http://localhost:8081,http://localhost:5173,http://localhost:3000
